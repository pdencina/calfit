{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/login",    "destination": "/index.html" },
    { "source": "/login/(.*)", "destination": "/index.html" },
    { "source": "/",         "destination": "/landing.html" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}